PORT=5000
CLIENT_URL=http://localhost:5173

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dealpost
DB_USER=root
DB_PASSWORD=your_mysql_password_here

JWT_SECRET=super_secret_change_me_in_production
JWT_EXPIRES_IN=7d

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_r2_bucket_name
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.com

IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1920
IMAGE_WEBP_QUALITY=75

# Browser key for Google Maps JavaScript API (restrict by HTTP referrer)
GOOGLE_MAPS_BROWSER_API_KEY=your_google_maps_browser_api_key_here

# Google OAuth Client ID (Web application type)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Firebase Admin SDK (server-side token verification)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# E2E Encryption - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY=your_64_character_hex_string_here

# Optional: set true to enforce GSTIN checksum validation (in addition to format)
GSTIN_VALIDATE_CHECKSUM=false

# Admin seeding (only used with: npm run seed:admin)
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=YourSecureAdminPassword123!
SEED_ADMIN_NAME=Super Admin
