#!/bin/bash
# Appwrite Setup Environment Variables
# Location: ~/appwrite/.env (on your VPS)
# 
# IMPORTANT: 
# - Replace placeholder values with your actual values
# - Keep API keys secure - never commit to git
# - Use strong random passwords for DB/Redis
# - Set correct domain names for your setup

# ============================================================================
# APPWRITE CORE CONFIGURATION
# ============================================================================

# Environment mode
_APP_ENV=production
_APP_LOCALE=en

# Domain configuration (CRITICAL)
_APP_DOMAIN=api.dealpost.in
_APP_DOMAIN_TARGET=api.dealpost.in

# Security keys (generate with: openssl rand -hex 32)
_APP_OPENSSL_KEY_V1=<generate-random-hex-32-chars>
_APP_OPENSSL_KEY_V2=<generate-random-hex-32-chars>

# Console settings
_APP_CONSOLE_WHITELIST_IPS=*

# ============================================================================
# DATABASE CONFIGURATION (MariaDB)
# ============================================================================

DB_PASSWORD=<strong-random-password-20-chars>
_APP_DB_HOST=mariadb
_APP_DB_PORT=3306
_APP_DB_USER=appwrite
_APP_DB_PASS=${DB_PASSWORD}
_APP_DB_SCHEMA=appwrite

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379

# ============================================================================
# INFLUXDB CONFIGURATION (Metrics)
# ============================================================================

INFLUX_PASSWORD=<strong-random-password-20-chars>
_APP_INFLUXDB_HOST=influxdb
_APP_INFLUXDB_PORT=8086
_APP_INFLUXDB_USERNAME=appwrite
_APP_INFLUXDB_PASSWORD=${INFLUX_PASSWORD}

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================

# Local storage (default)
_APP_STORAGE_DEVICE=local

# Optional: AWS S3
# Uncomment if using S3 for file storage
# _APP_STORAGE_DEVICE=s3
# _APP_STORAGE_S3_ACCESS_KEY=<your-aws-access-key>
# _APP_STORAGE_S3_SECRET=<your-aws-secret-key>
# _APP_STORAGE_S3_REGION=us-east-1
# _APP_STORAGE_S3_BUCKET=dealpost-storage

# ============================================================================
# EMAIL / SMTP CONFIGURATION (Optional)
# ============================================================================

# For transactional emails (password reset, verification, etc)
# Leave empty to disable email features

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=<your-app-password>

_APP_SMTP_HOST=${SMTP_HOST}
_APP_SMTP_PORT=${SMTP_PORT}
_APP_SMTP_SECURE=${SMTP_SECURE}
_APP_SMTP_USERNAME=${SMTP_USERNAME}
_APP_SMTP_PASSWORD=${SMTP_PASSWORD}

# ============================================================================
# OAUTH PROVIDERS (Optional)
# ============================================================================

# Google OAuth
# Obtain from: https://console.cloud.google.com
OAUTH_GOOGLE_APP_ID=<your-google-app-id>
OAUTH_GOOGLE_SECRET=<your-google-secret>

_APP_OAUTH_GOOGLE_APP_ID=${OAUTH_GOOGLE_APP_ID}
_APP_OAUTH_GOOGLE_SECRET=${OAUTH_GOOGLE_SECRET}

# GitHub OAuth
# Obtain from: https://github.com/settings/developers
OAUTH_GITHUB_APP_ID=<your-github-app-id>
OAUTH_GITHUB_SECRET=<your-github-secret>

_APP_OAUTH_GITHUB_APP_ID=${OAUTH_GITHUB_APP_ID}
_APP_OAUTH_GITHUB_SECRET=${OAUTH_GITHUB_SECRET}

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

_APP_LOGGING_CONFIG=""
_APP_LOGGING_LEVEL=error

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

_APP_SECURITY_EMAIL_IDENTITY_REVIEW=false
_APP_SECURITY_PHONE_IDENTITY_REVIEW=false
_APP_SECURITY_COOKIE_SECURE=true
_APP_SECURITY_COOKIE_HTTPONLY=true
_APP_SECURITY_COOKIE_SAMESITE=Strict

# ============================================================================
# FRONTEND SERVICE CONFIGURATION
# ============================================================================

# Location: frontend/.env
# Copy these values to your frontend environment file

VITE_APPWRITE_ENDPOINT=https://api.dealpost.in/v1
VITE_APPWRITE_PROJECT_ID=dealpost
VITE_APPWRITE_API_KEY=<your-frontend-api-key>

# ============================================================================
# BACKEND SERVICE CONFIGURATION
# ============================================================================

# Location: backend/.env
# Copy these values to your backend environment file

APPWRITE_ENDPOINT=https://api.dealpost.in/v1
APPWRITE_PROJECT_ID=dealpost
APPWRITE_API_KEY=<your-backend-api-key>
DB_ID=dealpost

# ============================================================================
# GENERATION INSTRUCTIONS
# ============================================================================

# Generate secure random passwords:
# Option 1 (Linux):
# openssl rand -base64 32

# Option 2 (macOS):
# LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32

# Option 3 (Online):
# https://www.random.org/strings/

# Generate OpenSSL keys:
# openssl rand -hex 32  # Run twice for KEY_V1 and KEY_V2

# ============================================================================
# SECURITY NOTES
# ============================================================================

# 1. Never commit this file to git - add to .gitignore
# 2. Use different passwords for dev/staging/production
# 3. Rotate API keys periodically
# 4. Keep backups of secrets in secure location (password manager)
# 5. Use strong passwords (minimum 20 characters)
# 6. Set file permissions: chmod 600 .env

# ============================================================================
# VERIFICATION CHECKLIST
# ============================================================================

# After filling all values:
# [ ] All passwords are strong (20+ chars, mixed case, numbers, symbols)
# [ ] Domain names are correct (api.dealpost.in, dealpost.in)
# [ ] OpenSSL keys generated and filled
# [ ] SMTP credentials verified (if using email)
# [ ] OAuth credentials created (if using social login)
# [ ] File saved with restricted permissions (chmod 600)
# [ ] Secrets manager/vault updated with backups

echo "✓ Environment file configured"
echo "❗ Keep this file secure - never share or commit to git"
